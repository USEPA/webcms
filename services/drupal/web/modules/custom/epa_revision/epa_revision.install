<?php

use Drupal\Core\Database\Database;
use Drupal\Core\Utility\UpdateException;

/**
 * Helper to drop a column and any non-primary indexes on it.
 *
 * @param string $table
 *   The table name.
 * @param string $column
 *   The column name.
 *
 * @return string
 *   Status message.
 *
 * @throws \Drupal\Core\Utility\UpdateException
 */
function _epa_revision_drop_column_if_exists($table, $column) {
  $connection = Database::getConnection();
  $schema = $connection->schema();

  if (!$schema->tableExists($table)) {
    return "Table $table does not exist.";
  }

  if (!$schema->fieldExists($table, $column)) {
    return "Column $column does not exist on $table.";
  }

  try {
    $indexes = $connection->query("
      SELECT INDEX_NAME
      FROM information_schema.statistics
      WHERE table_schema = DATABASE()
        AND table_name = :table
        AND column_name = :column
    ", [
      ':table' => $table,
      ':column' => $column,
    ])->fetchCol();

    foreach ($indexes as $index_name) {
      if ($index_name !== 'PRIMARY') {
        $connection->query("ALTER TABLE {" . $table . "} DROP INDEX `$index_name`");
      }
    }
  }
  catch (\Exception $e) {
    // Continue and try to drop the column anyway.
  }

  try {
    $connection->query("ALTER TABLE {" . $table . "} DROP COLUMN `$column`");
  }
  catch (\Exception $e) {
    throw new UpdateException('Failed to drop ' . $table . '.' . $column . ': ' . $e->getMessage());
  }

  return "Removed $column column from $table.";
}

/**
 * Removes leftover custom 'type' column from paragraphs_item_revision.
 */
function epa_revision_update_10002() {
  return _epa_revision_drop_column_if_exists('paragraphs_item_revision', 'type');
}

/**
 * Removes leftover custom 'type' column from paragraphs_item_revision_field_data.
 */
function epa_revision_update_10003() {
  return _epa_revision_drop_column_if_exists('paragraphs_item_revision_field_data', 'type');
}

/**
 * Removes leftover custom type columns from node and paragraphs revision tables.
 */
function epa_revision_update_10004() {
  $targets = [
    'paragraphs_item_revision' => 'type',
    'paragraphs_item_revision_field_data' => 'type',
    'node_revision' => 'type',
    'node_field_revision' => 'type',
  ];

  $messages = [];

  foreach ($targets as $table => $column) {
    $messages[] = _epa_revision_drop_column_if_exists($table, $column);
  }

  return implode(' ', $messages);
}

/**
 * Removes leftover custom bundle columns from media revision tables.
